# Environment
NODE_ENV=development

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username_without_at_sign

# LLM Backend ("openai", "claude", or "gemini")
LLM_BACKEND=openai

# OpenAI Configuration (used when LLM_BACKEND=openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Claude Configuration (used when LLM_BACKEND=claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Gemini Configuration (used when LLM_BACKEND=gemini)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Extra system prompt instructions (optional — appended after the built-in Professor Y prompt)
# LLM_SYSTEM_PROMPT=

# Production Deployment (CapRover)
# EXTERNAL_URL=https://your-app.your-domain.com
# PORT=80
