# Environment
NODE_ENV=development

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username_without_at_sign

# LLM API Keys (set whichever providers you want available)
# Default backend on first boot: claude / claude-haiku-4-5-20251001
# Switch model at runtime via /model command in private chat
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
LUMO_API_KEY=your_lumo_api_key_here

# Extra system prompt instructions (optional — appended after the built-in Professor Y prompt)
# LLM_SYSTEM_PROMPT=


# Google Maps (Places API + Geocoding API — required for search_map tool)
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# GitHub (required for GitHub MCP code search tools on Claude backend)
# GITHUB_TOKEN=your_github_personal_access_token_here

# Scheduler / Reminders
# REDIS_PASSWORD=your_redis_password

# Database (Prisma)
# SQLite (default, zero-setup dev):
# DATABASE_URL=file:./prisma/dev.db
# PostgreSQL (production — also change `provider` in prisma/schema.prisma to "postgresql"):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Production Deployment (CapRover)
# EXTERNAL_URL=https://your-app.your-domain.com
# PORT=80
# TELEGRAM_WEBHOOK_SECRET=generate_with__openssl_rand_-hex_32
